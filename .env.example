# Free AI (default) — sign up at https://console.groq.com (no credit card)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
# Optional: faster / lower token use on free tier
# GROQ_MODEL=llama-3.1-8b-instant
# Default: llama-3.3-70b-versatile

# Paid alternative — set AI_PROVIDER=openai and add OPENAI_API_KEY
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Server port for local development
PORT=3001
