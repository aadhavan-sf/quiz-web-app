# Free AI (default) — sign up at https://console.groq.com (no credit card)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
# Optional: faster / lower token use on free tier
# GROQ_MODEL=llama-3.1-8b-instant
# Default: llama-3.3-70b-versatile

# Paid alternative — set AI_PROVIDER=openai and add OPENAI_API_KEY
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Server port (Render sets PORT automatically)
PORT=3001

# Supabase — sign-in, session save/resume, profile (Vite uses VITE_ prefix, not NEXT_PUBLIC_)
# Run supabase/schema.sql in the Supabase SQL editor.
# Enable Google + Email under Authentication → Providers.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Use either the anon key or publishable key from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
# VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
